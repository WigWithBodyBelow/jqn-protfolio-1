---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';

const jsonLdData: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: 'Sobre Mi .. JQN',
  description: 'Conoce a Joaquin (JQN), poster artist argentino especializado en arte para teatro, musica y audiovisuales.',
  url: new URL('/sobre-mi/', Astro.site).href,
  mainEntity: {
    '@type': 'Person',
    name: 'Joaquin',
    alternateName: 'JQN',
    jobTitle: 'Poster Artist',
    knowsAbout: ['Poster Art', 'Graphic Design', 'Theater', 'Music', 'Audiovisual'],
    nationality: {
      '@type': 'Country',
      name: 'Argentina',
    },
  },
};
---

<BaseLayout
  title="Sobre Mi .. JQN"
  description="Conoce a Joaquin (JQN), poster artist argentino especializado en arte para teatro, musica y audiovisuales."
>
  <Fragment slot="head">
    <JsonLd data={jsonLdData} />
  </Fragment>

  <div class="about-page">
    <header class="page-header">
      <h1>Sobre Joaquin</h1>
    </header>

    <div class="about-content">
      <section class="bio-section">
        <div class="profile-image-placeholder" aria-label="Foto de Joaquin">
          <span aria-hidden="true">JQN</span>
        </div>

        <div class="bio-text">
          <p>
            Soy Joaquin, un poster artist argentino apasionado por el arte grafico y la
            narrativa visual. Mi trabajo explora la interseccion entre el teatro, la musica
            y el mundo audiovisual.
          </p>
          <p>
            Cada poster que creo busca capturar la esencia de una obra, un disco o una
            pelicula, transformando ideas en imagenes que cuentan historias por si solas.
          </p>
        </div>
      </section>

      <section class="skills-section" aria-label="Especialidades">
        <h2>Especialidades</h2>
        <ul class="skills-list">
          <li>Poster Art</li>
          <li>Diseno Grafico</li>
          <li>Identidad Visual</li>
          <li>Arte para Teatro</li>
          <li>Portadas Musicales</li>
          <li>Arte Audiovisual</li>
        </ul>
      </section>

      <section class="trajectory-section" aria-label="Trayectoria">
        <h2>Trayectoria</h2>
        <p>
          Con una formacion que combina diseno grafico y una profunda conexion con las
          artes escenicas, he desarrollado un estilo visual que fusiona tipografia
          expresiva, composicion cinematografica y una paleta que dialoga con el espiritu
          de cada proyecto.
        </p>
        <p>
          Mis trabajos incluyen posters no oficiales para obras de teatro reconocidas,
          portadas para artistas musicales emergentes, y piezas de arte inspiradas en la
          identidad cultural argentina.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: var(--fw-bold);
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .bio-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .bio-section {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .profile-image-placeholder {
    width: 200px;
    height: 200px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: var(--fw-bold);
    color: var(--color-text-muted);
  }

  .bio-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bio-text p {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .skills-section h2,
  .trajectory-section h2 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .skills-list li {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }

  .trajectory-section p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .trajectory-section p + p {
    margin-top: 1rem;
  }
</style>
