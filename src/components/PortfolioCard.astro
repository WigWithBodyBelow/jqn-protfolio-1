---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  title: string;
  subtitle: string;
  category?: string;
  image: ImageMetadata;
  imageAlt: string;
  loading?: 'eager' | 'lazy';
}

const { title, subtitle, category, image, imageAlt, loading = 'lazy' } = Astro.props;
---

<article class="portfolio-card">
  <Image
    src={image}
    alt={imageAlt}
    widths={[320, 480, 720, 1024]}
    sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, (max-width: 1439px) 33vw, 25vw"
    loading={loading}
    class="card-image"
  />
  <div class="card-overlay" aria-hidden="true">
    <h2 class="card-title">{title}</h2>
    <p class="card-subtitle">{subtitle}</p>
    {category && <p class="card-category">{category}</p>}
  </div>
</article>

<style>
  .portfolio-card {
    position: relative;
    overflow: hidden;
    aspect-ratio: auto;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, transparent 60%);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .portfolio-card:hover .card-overlay,
  .portfolio-card:focus-within .card-overlay {
    opacity: 1;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: var(--fw-bold);
    line-height: 1.3;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .card-subtitle {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: var(--fw-light);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .card-category {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: var(--fw-regular);
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }
</style>
