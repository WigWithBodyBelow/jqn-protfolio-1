---
import PortfolioCard from './PortfolioCard.astro';
import type { ImageMetadata } from 'astro';

export interface PortfolioItem {
  id: string;
  title: string;
  subtitle: string;
  category?: string;
  filterTags: readonly string[];
  image: ImageMetadata;
  imageAlt: string;
}

export interface Props {
  items: readonly PortfolioItem[];
}

const { items } = Astro.props;
const EAGER_THRESHOLD = 4;
---

<ul role="list" class="portfolio-grid" id="portfolio-grid">
  {
    items.map((item, index) => (
      <li data-tags={item.filterTags.join(',')}>
        <PortfolioCard
          title={item.title}
          subtitle={item.subtitle}
          category={item.category}
          image={item.image}
          imageAlt={item.imageAlt}
          loading={index < EAGER_THRESHOLD ? 'eager' : 'lazy'}
        />
      </li>
    ))
  }
</ul>

<style>
  .portfolio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .portfolio-grid > li[hidden] {
    display: none;
  }

  @media (min-width: 768px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .portfolio-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1440px) {
    .portfolio-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
